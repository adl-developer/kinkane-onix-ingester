# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://user:password@localhost:5432/kinkane

# Redis (shared with BullMQ)
REDIS_URL=redis://localhost:6379

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Prefix in the bucket where ONIX files live (e.g. "onix/")
R2_ONIX_PREFIX=onix/

# Public base URL for the R2 bucket (required for cover image re-hosting).
# When set, covers are downloaded from Google Books and stored in R2 under covers/
# so you own the URL and aren't dependent on Google's image CDN.
# Enable public access on the bucket in the Cloudflare dashboard, then set this
# to the public domain (custom domain or the r2.dev subdomain).
# e.g. https://pub-<hash>.r2.dev  OR  https://covers.yourdomain.com
# If not set, the Google Books URL is stored directly (still high-res, but external).
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# Google AI (Gemini)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_FLASH_MODEL=gemini-2.5-flash-lite

# Auth — secret used to issue admin JWTs
ADMIN_SECRET=change_me_to_a_long_random_string
JWT_SECRET=change_me_to_another_long_random_string

# Ingestion tuning
CHUNK_SIZE=500
EMBEDDING_BATCH_SIZE=100

# Cron schedule for polling R2 (default: daily at 02:00)
R2_POLL_CRON=0 2 * * *

GOOGLE_BOOKS_API_KEY=your_key_here   # from console.cloud.google.com → Books API
COVER_FETCH_CRON=0 3 * * *           # optional, 3 AM is the default
COVER_FETCH_BATCH_SIZE=50            # optional
COVER_FETCH_DELAY_MS=200             # optional

# Jellybooks excerpts (https://www.jellybooks.com/apis/excerpts/index.html)
JELLYBOOKS_API_KEY=your_key_here     # optional — excerpt sync is skipped if not set
JELLYBOOKS_BASE_URL=https://www.jellybooks.com  # optional
EXCERPT_SYNC_CRON=0 5 * * *          # optional, 5 AM is the default

# Master switch for all Gardners cron jobs and POST /gardners/bootstrap.
# Only the literal string 'true' enables it — leave unset/false on any
# database not sized for the full catalogue (~2M rows + cover images).
GARDNERS_INGESTION_ENABLED=false

# Gardners Books — Bespoke Inventory SFTP (dedicated account, daily price/stock feed)
GARDNERS_BESPOKE_SFTP_HOST=edi.gardners.com
GARDNERS_BESPOKE_SFTP_PORT=22
GARDNERS_BESPOKE_SFTP_USERNAME=your_username
GARDNERS_BESPOKE_SFTP_PASSWORD=your_password

# Gardners Books — Generic Data SFTP (Biblio/Avail13/Prom/Firmsale/isbnslip/mkres)
GARDNERS_GENERIC_SFTP_HOST=data.gardners.com
GARDNERS_GENERIC_SFTP_PORT=22
GARDNERS_GENERIC_SFTP_USERNAME=your_username
GARDNERS_GENERIC_SFTP_PASSWORD=your_password

# Gardners Books — Cover images, plain FTP (not SFTP), port 21
GARDNERS_COVERS_FTP_HOST=covers.gardners.com
GARDNERS_COVERS_FTP_PORT=21
GARDNERS_COVERS_FTP_USERNAME=your_username
GARDNERS_COVERS_FTP_PASSWORD=your_password

# Gardners feed cron schedules (UTC) — see README for rationale on each buffer
GARDNERS_INVENTORY_CRON=0 13 * * *           # daily, after the ~12:00 GMT file drop
GARDNERS_BIBLIO_DELTA_CRON=0 6 * * 1         # weekly, Monday
GARDNERS_AVAIL13_CRON=15 * * * *             # hourly, :15 past
GARDNERS_PROMOTIONS_CRON=0 14 * * *          # daily
GARDNERS_FIRM_SALE_CRON=0 7 * * 2            # weekly, Tuesday (placeholder — verify actual drop day)
GARDNERS_ISBN_SLIPS_CRON=30 7 * * 2          # weekly, Tuesday (placeholder — verify actual drop day)
GARDNERS_MARKET_RESTRICTIONS_CRON=0 8 * * *  # daily
GARDNERS_COVERS_UPDATE_CRON=0 9 * * 1        # weekly, Monday

GARDNERS_COVER_SYNC_BATCH_SIZE=200           # optional
GARDNERS_COVER_SYNC_DELAY_MS=100             # optional
